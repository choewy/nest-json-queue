{
  "name": "nest-json-queue",
  "version": "0.0.0",
  "description": "A persistent JSON file queue for NestJS",
  "license": "MIT",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "start": "nodemon -w src -e ts --exec ts-node src/index.ts",
    "dev": "concurrently -n producer,consumer -c auto \"nest start producer --watch\" \"nest start consumer --watch\"",
    "dev:producer": "nest start producer --watch",
    "dev:consumer": "nest start consumer --watch",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/nest-json-queue/test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/testing": "11.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "concurrently": "^10.0.3",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "semantic-release": "^25.0.5",
    "ts-jest": "29.4.11",
    "ts-loader": "9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "lint-staged": {
    "{src,apps,libs,test}/**/*.ts": "eslint --fix"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@libs$": "<rootDir>/src",
      "^@libs/(.*)$": "<rootDir>/src/$1"
    },
    "roots": [
      "<rootDir>/test/",
      "<rootDir>/apps/"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/choewy/nest-json-queue.git"
  },
  "keywords": [
    "nestjs",
    "queue",
    "json-queue",
    "file-queue",
    "persistent-queue",
    "job-queue",
    "task-queue",
    "json-file",
    "filesystem",
    "worker",
    "producer",
    "consumer",
    "retry"
  ],
  "author": "choewy",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/choewy/nest-json-queue/issues"
  },
  "homepage": "https://github.com/choewy/nest-json-queue#readme"
}
